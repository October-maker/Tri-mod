	"updateEffect": "mineBig", // 定义方块更新时的特效
	"rotateSpeed": 4, // 定义钻头旋转的速度
	"drawMineItem": true, // 定义是否显示正在挖掘的矿石
	"itemCapacity": 40, // 定义方块存储物品的容量
	"requirements": [ // 定义建造这个方块所需的材料和数量
        { "item": "MonocrystallineSi", "amount":10},
        { "item": "TiAlloy", "amount":24},
        { "item": "FeSteel", "amount":10} // 需要50个石墨
    ],
	"category": "production", // 定义方块所属的分类
	"research": "reinforcedDrill" // 定义研究这个方块所需的科技

{
	"itemCapacity":40,//物品容量，数字都能改别的
	"health":100,//生命值
	"outputsLiquid":true,//是否输出液体（别跟下面那个具体的弄混了）
	"size":3,//最高16，不然会崩
	"squareSprite": true,
	"researchCostMultiplier":0.75,
	"hasPower": true,//是否需要电
	"hasLiquids": true,//是否需要液体
	"hasItems": true,//是否需要物品
	"drawer":{
	    "type":"DrawMulti",
	    "drawers":[
	        {
            "type": "DrawRegion",
            "suffix": "-bottom"
            },
            {
            "type": "drawLiquidTile",
            "drawLiquid": "HCl",
            "padding": 2,
            },
	        "DrawDefault",
			{
			"type": "DrawGlowRegion", // 使用 "DrawGlowRegion" 组件来添加发光效果。
			"color": "FFFFFF99", // 指定发光的颜色，以十六进制表示。
			"layer": 110,
			"suffix": "-glow",
			"glowIntensity":0,
			},
	    ]
	},
	"buildCostMultiplier":0.8,//建造速度倍率
	"craftTime":45,//输出时间间隔
	"consumes": {
		"power":1,//耗电，游戏里会乘60
        "liquids":[
            "H2SO4/0.4",
            "salineWater/0.8"
        ],
	},//制造消耗
	"outputLiquid": { "liquid": "hydrochloricAcid", "amount": 0.6 },//输出的液体
	"outputItem": { "item": "NaHSO4", "amount": 3 },
	"updateEffect": "none",//制造完成时产生的效果
	"requirements": [
		"Ti/10",
		"TiAlloy/40",
		"Al/30",
	],
	"category": "crafting",//建造栏分类
	"research": "SAbsorptionTower",//前置研究

{
    "liquidOutputDirections":[1,3],
    "researchCostMultiplier":1.2,
    "rotate":true,
    "size":3,
    "liquidCapacity": 80,
    "regionRotated1":3,
    "squareSprite": true,
    "health":100,
    "outputsLiquid":true,
